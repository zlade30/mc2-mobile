require "securerandom"
require "json"
require "fileutils"

# #region agent log
def agent_debug_log(hypothesis_id, location, message, data = {})
  payload = {
    sessionId: "54106a",
    hypothesisId: hypothesis_id,
    location: location,
    message: message,
    data: data,
    timestamp: (Time.now.to_f * 1000).to_i
  }
  path = File.expand_path("../.cursor/debug-54106a.log", __dir__)
  FileUtils.mkdir_p(File.dirname(path))
  File.open(path, "a") { |f| f.puts(JSON.generate(payload)) }
  UI.message("AGENT_DEBUG #{hypothesis_id} #{message} #{data.inspect}")
rescue StandardError => e
  UI.message("agent_debug_log failed: #{e.message}")
end
# #endregion

default_platform(:ios)

platform :ios do
  lane :beta do
    ci_keychain = "fastlane_ci_mc2"
    # Ephemeral CI keychain: optional secret, or random password (keychain is deleted after the lane)
    keychain_pw = ENV["MATCH_KEYCHAIN_PASSWORD"].to_s.strip
    # GitHub Actions sets GITHUB_ACTIONS=true; CI may be unset on some images
    ci_build = ENV["CI"] == "true" || ENV["GITHUB_ACTIONS"] == "true"

    # #region agent log
    tf_bundle_preview = ENV["IOS_BUNDLE_ID"].to_s.strip
    export_plist = File.expand_path("ExportOptions.plist", __dir__)
    export_raw = File.exist?(export_plist) ? File.read(export_plist) : ""
    export_lists_bundle = tf_bundle_preview.empty? ? false : export_raw.include?("<key>#{tf_bundle_preview}</key>")
    agent_debug_log(
      "H1",
      "Fastfile:beta:entry",
      "lane_start",
      {
        ci_build: ci_build,
        github_actions: ENV["GITHUB_ACTIONS"] == "true",
        asc_hint: "Uploads appear under App Store Connect → Your App → TestFlight → Builds (processing can take several minutes).",
        ios_bundle_id_set: !tf_bundle_preview.empty?,
        ios_bundle_id_suffix: tf_bundle_preview.empty? ? nil : tf_bundle_preview.split(".").last(2).join(".")
      }
    )
    agent_debug_log(
      "H2",
      "Fastfile:beta:export_options",
      "bundle_vs_export_plist",
      {
        export_plist_lists_bundle: export_lists_bundle,
        ios_team_id_from_secret: !ENV["IOS_TEAM_ID"].to_s.strip.empty?
      }
    )
    # #endregion

    if ci_build && keychain_pw.empty?
      keychain_pw = SecureRandom.hex(24)
      UI.message("MATCH_KEYCHAIN_PASSWORD not set — using a one-time password for the ephemeral CI keychain")
    end

    begin
      if ci_build
        create_keychain(
          name: ci_keychain,
          password: keychain_pw,
          default_keychain: true,
          unlock: true,
          timeout: 3600,
          lock_when_sleeps: false
        )
      end

      api_key = app_store_connect_api_key(
        key_id: ENV["APPLE_API_KEY_ID"],
        issuer_id: ENV["APPLE_API_ISSUER_ID"],
        key_content: ENV["APPLE_API_KEY_CONTENT"],
        is_key_content_base64: false
      )

      # #region agent log
      agent_debug_log(
        "H5",
        "Fastfile:beta:after_api_key",
        "asc_api_key_env_present",
        {
          apple_api_key_id_set: !ENV["APPLE_API_KEY_ID"].to_s.strip.empty?,
          apple_api_issuer_id_set: !ENV["APPLE_API_ISSUER_ID"].to_s.strip.empty?,
          apple_api_key_content_set: !ENV["APPLE_API_KEY_CONTENT"].to_s.strip.empty?
        }
      )
      # #endregion

      match_params = {
        type: "appstore",
        readonly: true,
        git_url: ENV["MATCH_GIT_URL"],
        app_identifier: ENV["IOS_BUNDLE_ID"],
        api_key: api_key
      }
      if ci_build
        match_params[:keychain_name] = ci_keychain
        match_params[:keychain_password] = keychain_pw
      end
      match(match_params)

      # Expo prebuild often leaves the app target on manual signing without an App Store profile;
      # Xcode then looks for "iOS App Development" profiles. Point Release at match's App Store profile.
      if ci_build
        bundle_id = ENV["IOS_BUNDLE_ID"].to_s.strip
        UI.user_error!("IOS_BUNDLE_ID must be set for CI builds") if bundle_id.empty?

        team_id = ENV["IOS_TEAM_ID"].to_s.strip
        team_id = "Y4BQ9LRMZB" if team_id.empty?

        profile_name = "match AppStore #{bundle_id}"

        update_code_signing_settings(
          path: "ios/Mc.xcodeproj",
          use_automatic_signing: false,
          targets: ["Mc"],
          team_id: team_id,
          bundle_identifier: bundle_id,
          profile_name: profile_name,
          code_sign_identity: "Apple Distribution",
          build_configurations: ["Release"],
          sdk: "iphoneos*"
        )
      end

      if ci_build
        dev = ENV["DEVELOPER_DIR"].to_s.strip
        if dev.end_with?("/Developer") && dev.include?(".app")
          xcode_app = dev.sub(%r{/Contents/Developer\z}, "")
          if File.exist?("#{xcode_app}/Contents/Developer/usr/bin/xcodebuild")
            xcode_select(xcode_app)
          end
        end
      end

      build_app(
        workspace: "ios/Mc.xcworkspace",
        scheme: "Mc",
        configuration: "Release",
        export_method: "app-store",
        export_options: "fastlane/ExportOptions.plist",
        codesigning_identity: "Apple Distribution"
      )

      # #region agent log
      ipa_path = Actions.lane_context[SharedValues::IPA_OUTPUT_PATH]
      ipa_ok = ipa_path && File.exist?(ipa_path)
      agent_debug_log(
        "H3",
        "Fastfile:beta:after_gym",
        "ipa_after_build_app",
        {
          ipa_path_set: !ipa_path.to_s.empty?,
          ipa_exists: ipa_ok,
          ipa_size_bytes: ipa_ok ? File.size(ipa_path) : nil
        }
      )
      # #endregion

      tf_bundle_id = ENV["IOS_BUNDLE_ID"].to_s.strip
      UI.user_error!("IOS_BUNDLE_ID must be set to upload to TestFlight") if tf_bundle_id.empty?

      tf_team_id = ENV["IOS_TEAM_ID"].to_s.strip
      tf_team_id = "Y4BQ9LRMZB" if tf_team_id.empty?

      upload_to_testflight(
        api_key: api_key,
        app_identifier: tf_bundle_id,
        team_id: tf_team_id,
        skip_waiting_for_build_processing: true
      )

      # #region agent log
      latest_tf = Actions.lane_context[SharedValues::LATEST_TESTFLIGHT_BUILD_NUMBER]
      agent_debug_log(
        "H4",
        "Fastfile:beta:after_pilot",
        "upload_to_testflight_finished",
        {
          latest_testflight_build_number: latest_tf,
          pilot_succeeded_lane_context: !latest_tf.nil?
        }
      )
      # #endregion
    ensure
      if ci_build
        # Keychain may not exist if we failed before create_keychain (e.g. missing secret)
        begin
          delete_keychain(name: ci_keychain)
        rescue StandardError
          # ignore
        end
      end
    end
  end
end

platform :android do
  lane :internal do
    gradle(
      task: "bundle",
      build_type: "Release",
      project_dir: "android/",
      properties: {
        "android.injected.signing.store.file"     => ENV["KEYSTORE_PATH"],
        "android.injected.signing.store.password" => ENV["KEYSTORE_PASSWORD"],
        "android.injected.signing.key.alias"      => ENV["KEY_ALIAS"],
        "android.injected.signing.key.password"   => ENV["KEY_PASSWORD"],
      }
    )

    upload_to_play_store(
      track: "internal",
      aab: "android/app/build/outputs/bundle/release/app-release.aab",
      json_key_data: ENV["GOOGLE_PLAY_JSON_KEY"]
    )
  end
end
